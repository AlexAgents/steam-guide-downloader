/* ═══════════════════════════════════════════════════════
   Steam Guide Downloader — Dark Theme
   ═══════════════════════════════════════════════════════ */

/* ── Global ── */
QMainWindow {
    background-color: #1e1e2e;
}

QWidget {
    font-family: "Segoe UI", "SF Pro Display", "Helvetica Neue", sans-serif;
    font-size: 10pt;
    color: #cdd6f4;
}

/* ── Cards ── */
QFrame#card {
    background-color: #282a3a;
    border: 1px solid #3b3d52;
    border-radius: 10px;
}

/* ── Section labels ── */
QLabel#section_label {
    font-size: 10pt;
    font-weight: 600;
    color: #cdd6f4;
    padding: 0px 2px 2px 0px;
}

/* ── Toolbar labels ── */
QLabel#toolbar_label {
    font-size: 9pt;
    color: #8a8ea8;
    font-weight: 500;
}

/* ── Hint labels ── */
QLabel#hint_label {
    font-size: 8pt;
    color: #6c7086;
    padding-left: 4px;
}
QLabel#hint_label[state="valid"] {
    color: #a6e3a1;
}
QLabel#hint_label[state="invalid"] {
    color: #f38ba8;
}

/* ── Error labels ── */
QLabel#error_label {
    font-size: 8pt;
    color: #f38ba8;
    padding-left: 4px;
}

/* ── PDF status ── */
QLabel#pdf_status {
    font-size: 8pt;
    color: #6c7086;
}
QLabel#pdf_status[available="true"] {
    color: #a6e3a1;
}
QLabel#pdf_status[available="false"] {
    color: #f9e2af;
}

/* ── Line edits ── */
QLineEdit#url_input,
QLineEdit#path_input {
    background-color: #313244;
    border: 1.5px solid #3b3d52;
    border-radius: 8px;
    padding: 4px 10px;
    font-size: 10pt;
    color: #cdd6f4;
    selection-background-color: #89b4fa;
    selection-color: #1e1e2e;
}
QLineEdit#url_input:focus,
QLineEdit#path_input:focus {
    border-color: #89b4fa;
    background-color: #363849;
}
QLineEdit#url_input[state="valid"] {
    border-color: #a6e3a1;
}
QLineEdit#url_input[state="invalid"] {
    border-color: #f38ba8;
}
QLineEdit#url_input::placeholder,
QLineEdit#path_input::placeholder {
    color: #585b70;
}

/* ── ComboBoxes ── */
QComboBox#toolbar_combo {
    background-color: #313244;
    border: 1.5px solid #3b3d52;
    border-radius: 6px;
    padding: 2px 8px;
    font-size: 9pt;
    color: #cdd6f4;
    min-width: 80px;
}
QComboBox#toolbar_combo:hover {
    border-color: #89b4fa;
}
QComboBox#toolbar_combo::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 22px;
    border-left: 1px solid #3b3d52;
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px;
}
QComboBox#toolbar_combo::down-arrow {
    image: none;
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #8a8ea8;
    margin-right: 6px;
}
QComboBox QAbstractItemView {
    background-color: #313244;
    border: 1px solid #3b3d52;
    border-radius: 6px;
    padding: 4px;
    selection-background-color: #89b4fa;
    selection-color: #1e1e2e;
    outline: none;
}

/* ── Buttons ── */
QPushButton#btn_browse,
QPushButton#btn_clear {
    background-color: #313244;
    border: 1.5px solid #3b3d52;
    border-radius: 7px;
    padding: 4px 14px;
    font-size: 9pt;
    font-weight: 500;
    color: #cdd6f4;
}
QPushButton#btn_browse:hover,
QPushButton#btn_clear:hover {
    background-color: #3b3d52;
    border-color: #585b70;
}
QPushButton#btn_browse:pressed,
QPushButton#btn_clear:pressed {
    background-color: #585b70;
}

/* Download button */
QPushButton#btn_download {
    background-color: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #89b4fa, stop:1 #7096d6
    );
    border: none;
    border-radius: 10px;
    padding: 8px 20px;
    font-size: 11pt;
    font-weight: 700;
    color: #1e1e2e;
    letter-spacing: 0.5px;
}
QPushButton#btn_download:hover {
    background-color: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #a0c4ff, stop:1 #89b4fa
    );
}
QPushButton#btn_download:pressed {
    background-color: #5e82b8;
}
QPushButton#btn_download:disabled {
    background-color: #3b3d52;
    color: #585b70;
}

/* Cancel button */
QPushButton#btn_cancel {
    background-color: #313244;
    border: 1.5px solid #3b3d52;
    border-radius: 10px;
    font-size: 12pt;
    font-weight: 700;
    color: #f38ba8;
}
QPushButton#btn_cancel:hover {
    background-color: #45293a;
    border-color: #f38ba8;
}
QPushButton#btn_cancel:pressed {
    background-color: #f38ba8;
    color: #1e1e2e;
}
QPushButton#btn_cancel:disabled {
    color: #585b70;
    border-color: #3b3d52;
    background-color: #282a3a;
}

/* About button */
QPushButton#btn_about {
    background-color: transparent;
    border: 1.5px solid #3b3d52;
    border-radius: 13px;
    color: #8a8ea8;
    font-size: 13pt;
}
QPushButton#btn_about:hover {
    background-color: #3b3d52;
    color: #89b4fa;
}

/* ── Checkboxes ── */
QCheckBox {
    spacing: 6px;
    font-size: 9pt;
    color: #cdd6f4;
}
QCheckBox:disabled {
    color: #585b70;
}

/* ── Log area ── */
QTextEdit#log_area {
    background-color: #1e1e2e;
    border: 1.5px solid #3b3d52;
    border-radius: 8px;
    padding: 6px 8px;
    font-family: "Cascadia Code", "JetBrains Mono", "Consolas", monospace;
    font-size: 9pt;
    color: #cdd6f4;
    selection-background-color: #89b4fa;
    selection-color: #1e1e2e;
}

/* ── Progress bar ── */
QProgressBar#main_progress {
    background-color: #313244;
    border: none;
    border-radius: 2px;
    max-height: 4px;
}
QProgressBar#main_progress::chunk {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 #89b4fa, stop:1 #cba6f7
    );
    border-radius: 2px;
}

/* ── Status bar ── */
QStatusBar#main_status_bar {
    background-color: #181825;
    border-top: 1px solid #3b3d52;
    font-size: 8pt;
    color: #6c7086;
    padding: 2px 8px;
}

/* ── Scrollbars ── */
QScrollBar:vertical {
    background: transparent;
    width: 8px;
    margin: 0;
}
QScrollBar::handle:vertical {
    background: #585b70;
    border-radius: 4px;
    min-height: 30px;
}
QScrollBar::handle:vertical:hover {
    background: #8a8ea8;
}
QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0;
}
QScrollBar:horizontal {
    background: transparent;
    height: 8px;
    margin: 0;
}
QScrollBar::handle:horizontal {
    background: #585b70;
    border-radius: 4px;
    min-width: 30px;
}
QScrollBar::handle:horizontal:hover {
    background: #8a8ea8;
}
QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0;
}

/* ── Tooltips ── */
QToolTip {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #585b70;
    border-radius: 6px;
    padding: 5px 8px;
    font-size: 9pt;
}

/* ── Context menus ── */
QMenu {
    background-color: #313244;
    border: 1px solid #3b3d52;
    border-radius: 8px;
    padding: 4px 0px;
}
QMenu::item {
    padding: 6px 24px 6px 16px;
    font-size: 9pt;
    color: #cdd6f4;
}
QMenu::item:selected {
    background-color: #89b4fa;
    color: #1e1e2e;
    border-radius: 4px;
}
QMenu::separator {
    height: 1px;
    background: #3b3d52;
    margin: 4px 8px;
}

/* ── Message boxes ── */
QMessageBox {
    background-color: #282a3a;
}
QMessageBox QLabel {
    color: #cdd6f4;
    font-size: 10pt;
}
QMessageBox QPushButton {
    background-color: #313244;
    border: 1.5px solid #3b3d52;
    border-radius: 7px;
    padding: 6px 20px;
    font-size: 9pt;
    min-width: 70px;
    color: #cdd6f4;
}
QMessageBox QPushButton:hover {
    background-color: #3b3d52;
}
QMessageBox QPushButton:default {
    background-color: #89b4fa;
    color: #1e1e2e;
    border: none;
}
QMessageBox QPushButton:default:hover {
    background-color: #a0c4ff;
}

/* ── About dialog ── */
QDialog#about_dialog {
    background-color: #282a3a;
    border-radius: 12px;
}
QLabel#about_text {
    color: #cdd6f4;
}
QLabel#about_text a {
    color: #89b4fa;
}
QPushButton#about_close_btn {
    background-color: #313244;
    border: 1.5px solid #3b3d52;
    border-radius: 7px;
    padding: 6px 16px;
    font-size: 9pt;
    color: #cdd6f4;
}
QPushButton#about_close_btn:hover {
    background-color: #3b3d52;
}

/* ── File dialog ── */
QFileDialog {
    background-color: #282a3a;
}